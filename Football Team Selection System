var selectedPlayers = [];
var rejectedPlayers = [];
var selectedCount = 0;
var rejectedCount = 0;

var highestScore = fitnessScores[0];
var lowestScore = fitnessScores[0];
var highestPlayer = players[0];
var lowestPlayer = players[0];

var totalScore = 0;

for (i = 0; i < players.length; i++) {
    console.log(players[i] + ":" + fitnessScores[i])

    if (fitnessScores[i] >= 60) {
        console.log("selected");
        selectedPlayers.push(players[i]);
        selectedCount++;
    } else {
        console.log("rejected");
        rejectedPlayers.push(players[i]);
        rejectedCount++;
        totalScore += fitnessScores[i];
    }
}

console.log(Math.max(...players));
console.log(Math.min(...players));
console.log("selected players:" + selectedCount);
